    "# Cell 5 — Load base model + apply LoRA\n",
    "import torch\n",
    "from transformers import AutoModelForCausalLM\n",
    "from peft import LoraConfig, get_peft_model, TaskType\n",
    "\n",
    "device = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
    "print(f'Device: {device}')\n",
    "if device == 'cuda':\n",
    "    print(f'GPU: {torch.cuda.get_device_name(0)}')\n",
    "\n",
    "# Load in float32 — SFTConfig fp16=True handles mixed-precision internally.\n",
    "# Loading directly in float16 causes 'Attempting to unscale FP16 gradients' errors.\n",
    "model = AutoModelForCausalLM.from_pretrained(\n",
    "    BASE_MODEL,\n",
    "    torch_dtype=torch.float32,\n",
    "    device_map='auto'\n",
    ")\n",
    "model.config.use_cache = False\n",
    "print(f'Parameters (total): {model.num_parameters():,}')\n",
    "\n",
    "# LoRA: freeze base weights, train only low-rank adapters.\n",
    "# Preserves DPO instruction-following & 8192-token context window from pretraining.\n",
    "# r=16, alpha=32 is a standard starting point for 360M models.\n",
    "# target_modules covers all linear projections in the Llama attention + MLP blocks.\n",
    "lora_config = LoraConfig(\n",
    "    r=16,\n",
    "    lora_alpha=32,\n",
    "    target_modules=[\n",
    "        'q_proj', 'k_proj', 'v_proj', 'o_proj',\n",
    "        'gate_proj', 'up_proj', 'down_proj',\n",
    "    ],\n",
    "    lora_dropout=0.05,\n",
    "    bias='none',\n",
    "    task_type=TaskType.CAUSAL_LM,\n",
    ")\n",
    "model = get_peft_model(model, lora_config)\n",
    "model.print_trainable_parameters()\n",
    "# Expect: ~3-4M trainable / 360M total — ~1% of weights\n"
   ]
  },
