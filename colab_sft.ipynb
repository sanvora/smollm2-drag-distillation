    "import os\n",
    "from onnxruntime.quantization import quantize_dynamic, QuantType\n",
    "\n",
    "for root, dirs, files in os.walk(ONNX_DIR):\n",
    "    for f in files:\n",
    "        if f.endswith('.onnx') and 'quantized' not in f:\n",
    "            src = os.path.join(root, f)\n",
    "            dst = src.replace('.onnx', '_quantized.onnx')\n",
    "            print(f'Quantizing: {f}...')\n",
    "            try:\n",
    "                quantize_dynamic(\n",
    "                    model_input=src,\n",
    "                    model_output=dst,\n",
    "                    per_channel=False,\n",
    "                    reduce_range=False,\n",
    "                    weight_type=QuantType.QInt8,\n",
    "                    # Restrict to MatMul only: prevents float16 DequantizeLinear outputs\n",
    "                    # that crash ONNX Runtime Web (WASM). Gather/embedding ops stay float32.\n",
    "                    op_types_to_quantize=['MatMul'],\n",
    "                )\n",
    "                print(f' -> Success: {os.path.basename(dst)}')\n",
    "            except Exception as e:\n",
    "                print(f' -> Failed: {e}')\n"
   ]
  },
