    "import shutil\n",
    "import os\n",
    "\n",
    "!pip install -q \"optimum[exporters,onnxruntime]\" onnx onnxruntime\n",
    "\n",
    "if os.path.exists(ONNX_DIR):\n",
    "    shutil.rmtree(ONNX_DIR)\n",
    "os.makedirs(ONNX_DIR, exist_ok=True)\n",
    "print(f\"Exporting model from {CKPT_DIR} to {ONNX_DIR}...\")\n",
    "\n",
    "# Try CLI first; fall back to Python API if CLI fails (version mismatch)\n",
    "import subprocess, sys\n",
    "cli_result = subprocess.run(\n",
    "    [\n",
    "        sys.executable, \"-m\", \"optimum.exporters.onnx\",\n",
    "        \"--model\", CKPT_DIR,\n",
    "        \"--task\", \"text-generation-with-past\",\n",
    "        \"--dtype\", \"fp32\",\n",
    "        \"--opset\", \"18\",\n",
    "        ONNX_DIR,\n",
    "    ],\n",
    "    capture_output=True, text=True\n",
    ")\n",
    "onnx_files = [f for f in os.listdir(ONNX_DIR) if f.endswith('.onnx')] if os.path.exists(ONNX_DIR) else []\n",
    "if cli_result.returncode != 0 or not onnx_files:\n",
    "    print(\"CLI export failed, falling back to Python API...\")\n",
    "    if os.path.exists(ONNX_DIR):\n",
    "        shutil.rmtree(ONNX_DIR)\n",
    "    os.makedirs(ONNX_DIR, exist_ok=True)\n",
    "    from optimum.exporters.onnx import main_export\n",
    "    main_export(\n",
    "        model_name_or_path=CKPT_DIR,\n",
    "        output=ONNX_DIR,\n",
    "        task=\"text-generation-with-past\",\n",
    "        opset=18,\n",
    "        dtype=\"fp32\",\n",
    "    )\n",
    "\n",
    "print(\"ONNX export complete. Files:\", os.listdir(ONNX_DIR))\n"
   ]
  },
