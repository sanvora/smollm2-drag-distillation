    "import os\n",
    "\n",
    "# Merge LoRA adapters back into base weights before saving.\n",
    "# ONNX export and HF pipeline loading both require a plain AutoModelForCausalLM,\n",
    "# not a PeftModel — merge_and_unload() produces exactly that.\n",
    "print('Merging LoRA adapters into base weights...')\n",
    "merged_model = trainer.model.merge_and_unload()\n",
    "merged_model.save_pretrained(CKPT_DIR)\n",
    "tokenizer.save_pretrained(CKPT_DIR)\n",
    "print(f'Merged checkpoint saved to Drive: {CKPT_DIR}')\n",
    "\n",
    "# Push merged model to HF Hub\n",
    "HF_REPO = '<your-hf-username>/smollm2-drag'\n",
    "merged_model.push_to_hub(HF_REPO, commit_message='RAG-aware LoRA SFT: merged adapters (r=16, system+evidence+qa)')\n",
    "tokenizer.push_to_hub(HF_REPO)\n",
    "print(f'Pushed to: https://huggingface.co/{HF_REPO}')\n"
   ]
  },
