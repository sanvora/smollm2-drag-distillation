    "# Cell 9 — Quick sanity check\n",
    "# Tests both bare (old format) and RAG-grounded (new training format) prompts\n",
    "from transformers import pipeline\n",
    "\n",
    "pipe = pipeline(\n",
    "    \"text-generation\", model=CKPT_DIR, tokenizer=CKPT_DIR,\n",
    "    device=0 if device == \"cuda\" else -1\n",
    ")\n",
    "gen_kwargs = dict(max_new_tokens=150, do_sample=False, repetition_penalty=1.3)\n",
    "\n",
    "# Test 1: RAG-grounded (matches training_data_rag.jsonl format)\n",
    "rag_messages = [\n",
    "    {\n",
    "        \"role\": \"system\",\n",
    "        \"content\": (\n",
    "            \"You are a helpful assistant for Kham's portfolio. Be concise and accurate.\\n\"\n",
    "            \"Answer using ONLY these facts:\\n\"\n",
    "            \"1. Kham has 14 years of semiconductor hardware expertise and 5+ years deploying production \"\n",
    "            \"AI/ML systems at Florida Power & Light. He built outage prediction models and safety analytics pipelines.\"\n",
    "        )\n",
    "    },\n",
    "    {\"role\": \"user\", \"content\": \"What is Kham's background in AI/ML?\"}\n",
    "]\n",
    "result_rag = pipe(rag_messages, **gen_kwargs)\n",
    "print(\"=== RAG-grounded response ===\")\n",
    "print(result_rag[0][\"generated_text\"][-1][\"content\"])\n",
    "print()\n",
    "\n",
    "# Test 2: Bare prompt (sanity check baseline)\n",
    "bare_messages = [{\"role\": \"user\", \"content\": \"What are Kham's strongest technical skills?\"}]\n",
    "result_bare = pipe(bare_messages, **gen_kwargs)\n",
    "print(\"=== Bare prompt response ===\")\n",
    "print(result_bare[0][\"generated_text\"][-1][\"content\"])\n"
   ]
